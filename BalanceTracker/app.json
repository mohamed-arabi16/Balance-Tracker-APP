{
  "expo": {
    "name": "Balance Tracker",
    "slug": "balance-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "balancetracker",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.balancetracker.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Not used",
        "UIRequiresFullScreen": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.balancetracker.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-splash-screen",
      "expo-sqlite",
      "expo-symbols",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
